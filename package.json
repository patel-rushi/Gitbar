{
  "name": "gitbar",
  "version": "1.1.0",
  "description": "A macOS menu bar app that surfaces GitHub notifications that matter",
  "main": "dist-electron/main.js",
  "author": "Rushi Patel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/patel-rushi/GitBar.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && electron-builder",
    "preview": "vite preview",
    "prebuild": "node scripts/generate-tray-icons.js && node scripts/generate-icon.js",
    "electron:dev": "vite",
    "electron:build": "node scripts/generate-tray-icons.js && node scripts/generate-icon.js && vite build && electron-builder --mac",
    "electron:publish": "node scripts/generate-tray-icons.js && node scripts/generate-icon.js && vite build && electron-builder --mac --publish always"
  },
  "build": {
    "appId": "com.rushipatel.gitbar",
    "productName": "GitBar",
    "publish": {
      "provider": "github",
      "owner": "patel-rushi",
      "repo": "Gitbar"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.png",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "title": "GitBar",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "build",
        "to": "build",
        "filter": [
          "**/*.png"
        ]
      }
    ],
    "directories": {
      "output": "release"
    }
  },
  "dependencies": {
    "@aptabase/electron": "^0.3.1",
    "date-fns": "^3.6.0",
    "electron-updater": "^6.8.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@napi-rs/canvas": "^0.1.99",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.3",
    "vite": "^6.0.3",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "wait-on": "^8.0.1"
  }
}
